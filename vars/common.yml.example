# Shared variables used by every bootstrap and site playbook, on all OSes.
# OS-specific overrides live in vars/arch.yml and vars/ubuntu.yml.

# Dedicated admin account created by the bootstrap playbooks and used by the
# site playbooks over SSH.
ansible_admin_user: ansible
ansible_admin_shell: /bin/bash

# Tailscale. Leave the auth key empty to skip `tailscale up` (the daemon is
# still installed and started). Provide a key to auto-join the tailnet.
tailscale_authkey: ""
tailscale_hostname: "{{ inventory_hostname }}"

# The control plane every managed host ships to, and the single port its nginx
# proxy listens on. Loki and Splunk HEC are both reached here and told apart by
# URL path, so one address covers both. Use the control plane's Tailscale name
# once it has joined the tailnet.
control_plane_host: ""
control_plane_port: 80

# Port Prometheus node exporter listens on, and scrapes managed hosts at.
node_exporter_port: 9100

# Log files Fluent Bit tails and forwards to Loki.
fluent_bit_tail_paths:
  - /var/log/*.log

# Security log files Fluent Bit tails and forwards to Splunk HEC.
fluent_bit_security_tail_paths:
  - /var/log/audit/*.log

# High-signal auditd rules for identity, sudo, SSH, and polkit changes.
audit_rules:
  - "-w /etc/passwd -p wa -k identity"
  - "-w /etc/group -p wa -k identity"
  - "-w /etc/sudoers -p wa -k sudoers"
  - "-w /etc/sudoers.d/ -p wa -k sudoers"
  - "-w /etc/ssh/sshd_config -p wa -k sshd"
  - "-w /etc/polkit-1/ -p wa -k polkit"
  - "-w /usr/bin/sudo -p x -k sudo"
