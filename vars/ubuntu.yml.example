# Ubuntu-specific variables. Loaded after vars/common.yml, so values here
# override the shared defaults.

# Supplementary groups for the admin user. Ubuntu uses `sudo`.
ansible_admin_groups:
  - sudo

# Public SSH key file installed on the admin account by the bootstrap playbook.
ansible_admin_authorized_key_file: "{{ lookup('env', 'HOME') }}/.ssh/clippy_azure.pub"

# Packages installed by the site playbook (apt).
ubuntu_required_packages:
  - ca-certificates
  - curl
  - gnupg
  - auditd
  - tailscale
  - prometheus-node-exporter
  - fluent-bit

# Upstream osquery does not publish an ARM64 Debian package.
ubuntu_osquery_enabled: false

# External Loki endpoint host logs are forwarded to.
loki_host: "{{ inventory_hostname }}"
loki_port: 8080
loki_uri: /loki/api/v1/push

# External Splunk HEC endpoint security events are forwarded to.
splunk_hec_host: "{{ inventory_hostname }}"
splunk_hec_port: 8088
splunk_hec_token: ""
splunk_hec_index: security
splunk_hec_sourcetype: vm_security
splunk_hec_tls: true
