# Single inventory for every playbook. Each playbook picks its own group:
#   bootstrap/arch + site/arch      -> [arch_hosts]
#   bootstrap/ubuntu + site/ubuntu  -> [ubuntu_hosts]
#   site/control                    -> [control_hosts]
#
# provision-vms.sh generates this file for local libvirt VMs. Copy this example
# to inventory.ini instead when managing hosts you provisioned some other way.
#
# ansible_user is the steady-state `ansible` account the site playbooks use.
# The bootstrap stage runs once as an EXISTING admin instead -- override it per
# run, e.g.  -e ansible_user=azureuser

[arch_hosts]
control-stg ansible_host=192.168.123.234 ansible_ssh_private_key_file=~/.ssh/ansible-stg
app-stg     ansible_host=192.168.123.127 ansible_ssh_private_key_file=~/.ssh/ansible-stg

[arch_hosts:vars]
ansible_user=ansible

# The control plane. Also a member of arch_hosts, so it runs the same agents as
# every other managed host in addition to hosting the stack.
[control_hosts]
control-stg ansible_host=192.168.123.234 ansible_ssh_private_key_file=~/.ssh/ansible-stg

[control_hosts:vars]
ansible_user=ansible

[ubuntu_hosts]

[ubuntu_hosts:vars]
ansible_user=ansible
