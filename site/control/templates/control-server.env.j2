#jinja2: lstrip_blocks: True, trim_blocks: True
# Managed by Ansible (site/control/site-control.yml) -- do not edit on the host.
# Values come from vars/secrets.yml and vars/control.yml on the control machine.

GRAFANA_ADMIN_USER={{ grafana_admin_user }}
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password }}
GRAFANA_ROOT_URL={{ control_grafana_root_url }}

PROXY_BIND_ADDRESS={{ control_proxy_bind_address }}
PROXY_PORT={{ control_proxy_port }}

SPLUNK_PASSWORD={{ splunk_password }}
SPLUNK_HEC_TOKEN={{ splunk_hec_token }}

# SPLUNK_HEC_PORT and SPLUNK_GENERAL_TERMS are deliberately left to the
# compose defaults. nginx proxies /services/collector to splunk:8088 in a
# static config, so overriding the HEC port here would break that route
# without any error to point at it.
