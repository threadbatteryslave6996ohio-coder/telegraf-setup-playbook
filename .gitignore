# Real credentials — never commit.
# Keep secrets out of the tracked vars/*.yml files; put them in a local
# secrets file and pass it with -e @vars/secrets.yml, or use ansible-vault.
vars/secrets.yml
vars/*.secrets.yml
group_vars/*/secrets.yml

# Filled-in local config. Track only the *.example templates — these copies
# hold real hosts, keys, and tokens.
vars/arch.yml
vars/ubuntu.yml
vars/common.yml
inventory.ini
inventory.tailscale.ini
