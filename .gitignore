# Real per-environment config — never commit.
#
# Each inventories/<env>/ directory holds real hosts, keys, tokens and
# secrets in its group_vars/all/. Only the inventories/example/ template is
# tracked; copy it to create a new environment.
inventories/*
!inventories/example

# Legacy layout, superseded by inventories/<env>/. Kept ignored so any
# leftover local copies never land in git.
vars/secrets.yml
vars/*.secrets.yml
vars/arch.yml
vars/ubuntu.yml
vars/common.yml
vars/control.yml
group_vars/*/secrets.yml
inventory.ini
inventory.tailscale.ini
